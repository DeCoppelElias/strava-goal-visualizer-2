# Copy this file to .env and fill in real values. Never commit .env.
# See design doc §12 for security requirements.

# ---- Strava OAuth ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8501/oauth/callback

# ---- Database ----
# asyncpg DSN: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/strava_dev

# ---- Session ----
# At least 32 random characters
SESSION_SECRET_KEY=

# ---- Token encryption ----
# 64 hex characters (256-bit key). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=

# ---- Frontend ----
# Full URL of the FastAPI backend reachable from the user's browser
API_BASE_URL=http://localhost:8000
# Origin of the Streamlit frontend (used by backend for CORS)
FRONTEND_ORIGIN=http://localhost:8501

# ---- Python path ----
# Must be set as a shell variable before launching — NOT loaded by python-dotenv.
# Ensures the project root is on sys.path so 'frontend.*' and 'backend.*' imports resolve.
# PowerShell: $env:PYTHONPATH="."
# bash/zsh:   export PYTHONPATH=.
