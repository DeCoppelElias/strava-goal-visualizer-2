# Copy this file to .env and fill in real values. Never commit .env.
# See design doc §12 for security requirements.

# ---- Strava OAuth ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/oauth/callback

# ---- Database ----
# asyncpg DSN: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/strava_dev

# ---- Session ----
# Used by Starlette SessionMiddleware to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Set to false ONLY for local HTTP development. Production default is true (Secure cookie).
# SESSION_COOKIE_SECURE=false

# ---- Token encryption ----
# Fernet key (44 chars). Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ---- Frontend ----
# URL of the FastAPI backend reachable from the USER'S BROWSER (not server-to-server)
VITE_API_BASE_URL=http://localhost:8000
# Origin of the React frontend (used by backend for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# ---- Sync ----
# Per-user cooldown between syncs in seconds. Default: 600 (10 minutes).
# Set lower in development for faster iteration, e.g. SYNC_COOLDOWN_SECONDS=5
# SYNC_COOLDOWN_SECONDS=600

# ---- Strava webhook ----
# A string you choose freely. Used to verify the hub.verify_token that Strava
# sends during webhook subscription setup. Set this to any random string, then
# use the same value when registering the webhook subscription with Strava.
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
STRAVA_WEBHOOK_VERIFY_TOKEN=
